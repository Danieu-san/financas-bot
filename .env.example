# Core integrations
SPREADSHEET_ID=your_google_spreadsheet_id
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_REFRESH_TOKEN=your_google_oauth_refresh_token

# Per-user Google OAuth (multiuser)
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_web_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_web_client_secret
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_OAUTH_STATE_SECRET=replace_with_a_long_random_secret
GOOGLE_OAUTH_STATE_TTL_SECONDS=7200
OAUTH_TOKEN_ENCRYPTION_KEY=base64_32_byte_key
OAUTH_TOKEN_DB_PATH=
AUTH_GATE_REPLY_COOLDOWN_MS=86400000

# Admins: WhatsApp ids separated by comma, for example 5521999999999@c.us,1510...@lid
ADMIN_IDS=

# Legal / consent
TERMS_VERSION=v1.1
TERMS_URL=
PRIVACY_URL=

# Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_V2_ENABLED=true
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8787
DASHBOARD_BASE_URL=https://your-public-domain-or-ip:8787
DASHBOARD_TOKEN_SECRET=replace_with_a_long_random_secret
DASHBOARD_TOKEN_TTL_SECONDS=7200
DASHBOARD_TOKEN_MAX_TTL_SECONDS=86400
DASHBOARD_REQUIRE_STRONG_SECRET=true

# Runtime / production behavior
NODE_ENV=production
VALIDATE_USER_ID_ON_STARTUP=true
AUTO_BACKFILL_USER_ID_ON_STARTUP=false
READ_MODEL_SYNC_INTERVAL_MS=600000
USER_SERVICE_CACHE_TTL_MS=60000

# WhatsApp Web / Puppeteer
WWEB_CACHE_TYPE=none
WWEB_VERSION=
WWEB_USER_AGENT=
WWEB_READY_TIMEOUT_MS=120000
PUPPETEER_PROTOCOL_TIMEOUT_MS=120000

# Gemini tuning
GEMINI_TIMEOUT_MS=12000
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_DELAY_MS=800
GEMINI_SLOW_LOG_MS=4000
MESSAGE_SLOW_LOG_MS=10000

# Read-only financial agent
FINANCIAL_AGENT_MODE=off
# Canary only: comma-separated authorized user_ids. Empty fails closed.
FINANCIAL_AGENT_CANARY_USER_IDS=
FINANCIAL_AGENT_LLM_PLANNER_ENABLED=false
FINANCIAL_CONTEXTUAL_ANALYST_MODE=off
FINANCIAL_CONTEXTUAL_ANALYST_MAX_PROMPT_CHARS=12000

# Rate limiting
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60000
DISABLE_RATE_LIMITER=false

# Optional future state-store backend
STATE_STORE_DRIVER=file
REDIS_URL=
REDIS_STATE_KEY=financas-bot:state

# Operational alerts
OPERATIONAL_ALERTS_ENABLED=false

# Interpretation reliability rollout
INTERPRETATION_RELIABILITY_MODE=off
INTERPRETATION_RELIABILITY_OPERATIONS=expense.create,income.create
INTERPRETATION_RELIABILITY_ENFORCE_APPROVED=false
INTERPRETATION_RELIABILITY_TELEMETRY_PATH=data/interpretation-reliability-shadow.jsonl

# Fase 8B.0: telemetria duravel e sanitizada de uso/fallback de legado.
# Habilitar somente depois do gate de privacidade; usar segredo exclusivo >= 16 caracteres.
LEGACY_USAGE_TELEMETRY_ENABLED=false
LEGACY_USAGE_TELEMETRY_PATH=data/legacy-usage-telemetry.jsonl
LEGACY_USAGE_TELEMETRY_HMAC_SECRET=
LEGACY_USAGE_TELEMETRY_MAX_BYTES=5242880
LEGACY_USAGE_TELEMETRY_MAX_BACKUPS=4
INTERPRETATION_RELIABILITY_ALERTS_ENABLED=true

# Unified financial command planner rollout
FINANCIAL_COMMAND_PLANNER_MODE=off
FINANCIAL_COMMAND_PLANNER_CANARY_USER_IDS=

# Projected plan writes: off by default; shadow requires an exact user_id allowlist.
PROJECTED_PLAN_WRITES_MODE=off
PROJECTED_PLAN_WRITES_USER_IDS=
PROJECTED_PLANS_DB_PATH=data/projected-plans-identity.sqlite

# Batch maintenance: off by default; canary requires an exact user_id allowlist.
BATCH_MAINTENANCE_MODE=off
BATCH_MAINTENANCE_USER_IDS=

# Financial XLS/XLSX import and filtered export: off by default; canary requires an exact user_id allowlist.
FINANCIAL_FILE_IO_MODE=off
FINANCIAL_FILE_IO_USER_IDS=
FINANCIAL_FILE_IO_E2E_USER_LOOKUP=

# Linked financial receipts: off by default; canary requires an exact user_id allowlist.
FINANCIAL_RECEIPTS_MODE=off
FINANCIAL_RECEIPTS_USER_IDS=
FINANCIAL_RECEIPT_MAX_BYTES=5242880
FINANCIAL_RECEIPTS_DB_PATH=data/financial-receipts.sqlite
FINANCIAL_RECEIPTS_E2E_USER_LOOKUP=

# OCR import staging: off by default; output still requires normal import preview and confirmation.
FINANCIAL_DOCUMENT_OCR_MODE=off
FINANCIAL_DOCUMENT_OCR_USER_IDS=
FINANCIAL_DOCUMENT_OCR_MAX_BYTES=5242880
FINANCIAL_DOCUMENT_OCR_E2E_USER_LOOKUP=

# Test-only flags: keep disabled in production
RUN_FUNCTIONAL_TESTS=false
WHATSAPP_E2E_TEST_USER_LOOKUP=
PROJECTED_PLAN_E2E_USER_LOOKUP=
BACKFILL_ALLOW_SINGLE_USER_FALLBACK=false
FINANCIAL_UNDO_MODE=off
FINANCIAL_UNDO_USER_IDS=
FINANCIAL_UNDO_DB_PATH=./data/financial-undo.sqlite
FINANCIAL_UNDO_E2E_USER_LOOKUP=
# Read-model de cartao: off | canary (somente planilhas pessoais) | on
CARD_READ_MODEL_UNIFIED_FIRST_MODE=off
# Scheduler mensal de cartao: off | canary (fontes pessoais) | on
CARD_SCHEDULER_UNIFIED_FIRST_MODE=off
# Validacao read-only de user_id em cartoes: off | canary | on
CARD_USER_ID_VALIDATION_UNIFIED_FIRST_MODE=off

# Fase 9C: Pluggy/Meu Pluggy somente leitura e somente staging.
# Nunca versionar valores reais nem ativar no runtime principal antes do gate 9C.
PLUGGY_LIVE_READ_ENABLED=false
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
# Alternativa recomendada: arquivo privado no cofre BitLocker, fora do Git.
PLUGGY_CREDENTIALS_FILE=
# Preferir arquivo JSON privado dentro de data/ (ignorado pelo Git).
# Formato: [{"itemId":"...","alias":"daniel_nubank","ownerScope":"daniel"}]
PLUGGY_ITEM_MAP_FILE=data/open-finance/pluggy-item-map.json
PLUGGY_ITEM_MAP_JSON=
OPEN_FINANCE_LIVE_STAGING_DB=data/open-finance/live-staging.sqlite
OPEN_FINANCE_LIVE_STAGING_SECRET=
