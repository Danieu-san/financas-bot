# Core integrations
SPREADSHEET_ID=your_google_spreadsheet_id
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_REFRESH_TOKEN=your_google_oauth_refresh_token

# Per-user Google OAuth (multiuser)
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_web_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_web_client_secret
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_OAUTH_STATE_SECRET=replace_with_a_long_random_secret
GOOGLE_OAUTH_STATE_TTL_SECONDS=7200
GOOGLE_OAUTH_ATTEMPT_LEASE_MS=120000
GOOGLE_OAUTH_ATTEMPT_MAX_ATTEMPTS=5
GOOGLE_OAUTH_ATTEMPT_RETRY_BASE_MS=1000
GOOGLE_OAUTH_ATTEMPT_RETENTION_MS=604800000
GOOGLE_OAUTH_CONCURRENT_WAIT_MS=10000
OAUTH_SQLITE_BUSY_TIMEOUT_MS=5000
OAUTH_TOKEN_ENCRYPTION_KEY=base64_32_byte_key
OAUTH_TOKEN_DB_PATH=
AUTH_GATE_REPLY_COOLDOWN_MS=86400000
# Durable OAuth revocation jobs
OAUTH_REVOCATION_TIMEOUT_MS=5000
OAUTH_REVOCATION_RETENTION_DAYS=30
OAUTH_REVOCATION_MAX_ATTEMPTS=5
OAUTH_REVOCATION_RETRY_BASE_MS=300000
OAUTH_REVOCATION_RETRY_MAX_MS=86400000
# Durable Drive membership revocation jobs
SHARED_PERMISSION_REVOCATION_TIMEOUT_MS=5000
SHARED_PERMISSION_REVOCATION_RETENTION_DAYS=30
SHARED_PERMISSION_REVOCATION_MAX_ATTEMPTS=5
SHARED_PERMISSION_REVOCATION_RETRY_BASE_MS=300000
SHARED_PERMISSION_REVOCATION_RETRY_MAX_MS=86400000

# Admins: WhatsApp ids separated by comma, for example 5521999999999@c.us,1510...@lid
ADMIN_IDS=

# Private family allowlist. Disabled by default; configure only with internal ids.
FAMILY_MODE_ENABLED=false
FAMILY_MODE_USER_IDS=
FAMILY_MODE_WHATSAPP_IDS=

# Legal / consent
TERMS_VERSION=v1.1
TERMS_URL=
PRIVACY_URL=
USER_MANUAL_URL=
# Deprecated compatibility alias; prefer USER_MANUAL_URL.
FINANCASBOT_USER_MANUAL_URL=

# Dashboard
DASHBOARD_ENABLED=true
DASHBOARD_V2_ENABLED=true
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8787
DASHBOARD_BASE_URL=https://your-public-domain-or-ip:8787
DASHBOARD_TOKEN_SECRET=replace_with_a_long_random_secret
DASHBOARD_TOKEN_TTL_SECONDS=7200
DASHBOARD_TOKEN_MAX_TTL_SECONDS=86400
DASHBOARD_REQUIRE_STRONG_SECRET=true
DASHBOARD_ADMIN_ALL_USERS_ENABLED=false
DASHBOARD_ACCESS_LOG_ENABLED=true
DASHBOARD_ACCESS_LOG_PATH=

# Runtime / production behavior
NODE_ENV=production
APP_COMMIT_SHA=
GIT_COMMIT_SHA=
VALIDATE_USER_ID_ON_STARTUP=true
AUTO_BACKFILL_USER_ID_ON_STARTUP=false
READ_MODEL_SYNC_INTERVAL_MS=600000
USER_SERVICE_CACHE_TTL_MS=60000
DAILY_OPS_CHECK_ENABLED=false
# Deprecated compatibility maps. Prefer persisted users and family membership.
USER_MAP=
LEGACY_USER_MAP=

# WhatsApp Web / Puppeteer
WWEB_CACHE_TYPE=none
WWEB_VERSION=
WWEB_USER_AGENT=
WWEB_READY_TIMEOUT_MS=120000
WWEB_AUTH_TIMEOUT_MS=180000
WWEB_READY_RESCUE_DELAY_MS=15000
PUPPETEER_PROTOCOL_TIMEOUT_MS=120000
WHATSAPP_UNREAD_BACKFILL_ON_READY=true
WHATSAPP_UNREAD_BACKFILL_DELAY_MS=3000
WHATSAPP_UNREAD_BACKFILL_MAX_PER_CHAT=20
WHATSAPP_UNREAD_BACKFILL_LOOKBACK_SECONDS=60

# Gemini tuning
GEMINI_TIMEOUT_MS=12000
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_DELAY_MS=800
GEMINI_SLOW_LOG_MS=4000
MESSAGE_SLOW_LOG_MS=10000

# Google API reliability and local read cache
GOOGLE_API_RETRY_ATTEMPTS=3
GOOGLE_API_RETRY_DELAY_MS=30000
GOOGLE_SHEETS_READ_CACHE_TTL_MS=20000

# Read-only financial agent
FINANCIAL_AGENT_MODE=off
# Canary only: comma-separated authorized user_ids. Empty fails closed.
FINANCIAL_AGENT_CANARY_USER_IDS=
FINANCIAL_AGENT_LLM_PLANNER_ENABLED=false
FINANCIAL_AGENT_LLM_PLANNER_APPROVED=false
FINANCIAL_AGENT_ANSWER_APPROVED=false
FINANCIAL_AGENT_SHADOW_RECENT_ANSWER_ENABLED=false
FINANCIAL_AGENT_LOG_FULL=false
FINANCIAL_AGENT_ANALYTICAL_LEGACY_FALLBACK_DISABLED_DOMAINS=
FINANCIAL_AGENT_MAX_MODEL_CALLS_PER_QUESTION=2
FINANCIAL_AGENT_MAX_MODEL_CALLS_PER_MONTH=240
FINANCIAL_AGENT_COST_STATE_PATH=
FINANCIAL_AGENT_CHARS_PER_TOKEN=4
FINANCIAL_AGENT_INPUT_USD_PER_MILLION_TOKENS=
FINANCIAL_AGENT_OUTPUT_USD_PER_MILLION_TOKENS=
FINANCIAL_CONTEXTUAL_ANALYST_MODE=off
FINANCIAL_CONTEXTUAL_ANALYST_MAX_PROMPT_CHARS=12000

# Rate limiting
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60000
DISABLE_RATE_LIMITER=false

# Optional future state-store backend
STATE_STORE_DRIVER=file
STATE_STORE_ENCRYPTION_KEY=base64_32_byte_key
# Default 24 hours; hard maximum 30 days.
STATE_STORE_MAX_RETENTION_SECONDS=86400
REDIS_URL=
REDIS_STATE_KEY=financas-bot:state

# Operational alerts
OPERATIONAL_ALERTS_ENABLED=false
ADMIN_ACTION_LOG_ENABLED=true
ADMIN_ACTION_LOG_PATH=
QA_FAILURE_LOG_ENABLED=true
QA_FAILURE_LOG_PATH=

# Interpretation reliability rollout
INTERPRETATION_RELIABILITY_MODE=off
INTERPRETATION_RELIABILITY_OPERATIONS=expense.create,income.create
INTERPRETATION_RELIABILITY_ENFORCE_APPROVED=false
INTERPRETATION_RELIABILITY_TELEMETRY_PATH=data/interpretation-reliability-shadow.jsonl

# Fase 8B.0: telemetria duravel e sanitizada de uso/fallback de legado.
# Habilitar somente depois do gate de privacidade; usar segredo exclusivo >= 16 caracteres.
LEGACY_USAGE_TELEMETRY_ENABLED=false
LEGACY_USAGE_TELEMETRY_PATH=data/legacy-usage-telemetry.jsonl
LEGACY_USAGE_TELEMETRY_HMAC_SECRET=
LEGACY_USAGE_TELEMETRY_MAX_BYTES=5242880
LEGACY_USAGE_TELEMETRY_MAX_BACKUPS=4
INTERPRETATION_RELIABILITY_ALERTS_ENABLED=true
# Fase 8 acelerada: observar entrypoints; lista de soft-disable vazia ate gate proprio.
LEGACY_RETIREMENT_TRIPWIRE_ENABLED=false
LEGACY_RETIREMENT_SOFT_DISABLED_CANDIDATES=

# Unified financial command planner rollout
FINANCIAL_COMMAND_PLANNER_MODE=off
FINANCIAL_COMMAND_PLANNER_CANARY_USER_IDS=
FINANCIAL_COMMAND_PLANNER_ROUTE_OPERATIONS=
FINANCIAL_COMMAND_PLANNER_TELEMETRY_PATH=
FINANCIAL_COMMAND_PLANNER_CANARY_TELEMETRY_PATH=

# Canonical ledger rollout. All reads and writes remain off by default.
CANONICAL_LEDGER_PROJECTION_MODE=off
CANONICAL_LEDGER_SHADOW_WRITE_ENABLED=false
CANONICAL_LEDGER_PRODUCTION_SHADOW_APPROVED=false
CANONICAL_LEDGER_CANARY_READ_ENABLED=false
CANONICAL_LEDGER_CANARY_READ_APPROVED=false
CANONICAL_LEDGER_CANARY_READ_DOMAINS=
CANONICAL_LEDGER_SHADOW_DB_PATH=data/canonical_ledger_shadow.sqlite

# Projected plan writes: off by default; shadow requires an exact user_id allowlist.
PROJECTED_PLAN_WRITES_MODE=off
PROJECTED_PLAN_WRITES_USER_IDS=
PROJECTED_PLANS_DB_PATH=data/projected-plans-identity.sqlite

# Batch maintenance: off by default; canary requires an exact user_id allowlist.
BATCH_MAINTENANCE_MODE=off
BATCH_MAINTENANCE_USER_IDS=
BATCH_MAINTENANCE_WRITE_DB_PATH=data/financial_write_operations.sqlite

# Financial XLS/XLSX import and filtered export: off by default; canary requires an exact user_id allowlist.
FINANCIAL_FILE_IO_MODE=off
FINANCIAL_FILE_IO_USER_IDS=
FINANCIAL_FILE_IO_E2E_USER_LOOKUP=
IMPORT_MAX_FILE_BYTES=1048576
IMPORT_MAX_ROWS=1000

# Linked financial receipts: off by default; canary requires an exact user_id allowlist.
FINANCIAL_RECEIPTS_MODE=off
FINANCIAL_RECEIPTS_USER_IDS=
FINANCIAL_RECEIPT_MAX_BYTES=5242880
FINANCIAL_RECEIPTS_DB_PATH=data/financial-receipts.sqlite
FINANCIAL_RECEIPTS_E2E_USER_LOOKUP=

# OCR import staging: off by default; output still requires normal import preview and confirmation.
FINANCIAL_DOCUMENT_OCR_MODE=off
FINANCIAL_DOCUMENT_OCR_USER_IDS=
FINANCIAL_DOCUMENT_OCR_MAX_BYTES=5242880
FINANCIAL_DOCUMENT_OCR_E2E_USER_LOOKUP=

# Test-only flags: keep disabled in production
RUN_FUNCTIONAL_TESTS=false
WHATSAPP_E2E_ENABLED=false
WHATSAPP_E2E_BOT_PHONE=
WHATSAPP_E2E_TEST_USER_PHONE=
WHATSAPP_E2E_BOT_CHAT_NAME=
WHATSAPP_E2E_TIMEOUT_MS=60000
WHATSAPP_E2E_HEADLESS=false
WHATSAPP_E2E_RESET_SPREADSHEET=false
WHATSAPP_E2E_SENDER_KIND=personal-temporary
WHATSAPP_E2E_PROFILE_DIR=.e2e/whatsapp-sender-profile
WHATSAPP_E2E_TEST_USER_LOOKUP=
PROJECTED_PLAN_E2E_USER_LOOKUP=
BACKFILL_ALLOW_SINGLE_USER_FALLBACK=false
FINANCIAL_UNDO_MODE=off
FINANCIAL_UNDO_USER_IDS=
FINANCIAL_UNDO_DB_PATH=./data/financial-undo.sqlite
FINANCIAL_UNDO_E2E_USER_LOOKUP=
# Read-model de cartao: off | canary (somente planilhas pessoais) | on
CARD_READ_MODEL_UNIFIED_FIRST_MODE=off
# Scheduler mensal de cartao: off | canary (fontes pessoais) | on
CARD_SCHEDULER_UNIFIED_FIRST_MODE=off
# Validacao read-only de user_id em cartoes: off | canary | on
CARD_USER_ID_VALIDATION_UNIFIED_FIRST_MODE=off

# Fase 9C: Pluggy/Meu Pluggy somente leitura e somente staging.
# Nunca versionar valores reais nem ativar no runtime principal antes do gate 9C.
PLUGGY_LIVE_READ_ENABLED=false
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
# Alternativa recomendada: arquivo privado no cofre BitLocker, fora do Git.
PLUGGY_CREDENTIALS_FILE=
# Preferir arquivo JSON privado dentro de data/ (ignorado pelo Git).
# Formato: [{"itemId":"...","alias":"daniel_nubank","ownerScope":"daniel"}]
PLUGGY_ITEM_MAP_FILE=data/open-finance/pluggy-item-map.json
PLUGGY_ITEM_MAP_JSON=
OPEN_FINANCE_LIVE_STAGING_DB=data/open-finance/live-staging.sqlite
OPEN_FINANCE_LIVE_STAGING_SECRET=
OPEN_FINANCE_BASELINE_DB=
# 9E: off | shadow | canary. `on` permanece proibido antes de 9F.
OPEN_FINANCE_ALERT_MODE=off
# Compatibilidade com canario antigo de alias unico.
OPEN_FINANCE_ALERT_CANARY_ALIAS=
# Canario multi-fonte: aliases separados por virgula e cutoff ISO por alias.
OPEN_FINANCE_ALERT_CANARY_ALIASES=
OPEN_FINANCE_ALERT_CANARY_ACTIVATIONS_JSON=
OPEN_FINANCE_WRITE_MODE=off
# off | canary. Em canary, somente eventos `new` conciliados podem chegar ao outbox.
OPEN_FINANCE_RECONCILIATION_MODE=off
OPEN_FINANCE_SHADOW_PREVIEW_MODE=off
OPEN_FINANCE_SHADOW_PREVIEW_DB=
OPEN_FINANCE_COMMERCIAL_EVIDENCE_FILE=
OPEN_FINANCE_VISIBILITY_POLICY_FILE=
OPEN_FINANCE_OUTBOX_DB=
OPEN_FINANCE_REVOCATION_JOURNAL_DB=
OPEN_FINANCE_BACKUP_ROOT=
OPEN_FINANCE_LIVE_STAGING_SECRET_FILE=
# Read-only API polling cannot force the bank/Meu Pluggy to refresh. Minimum: 6h.
OPEN_FINANCE_POLL_INTERVAL_MS=21600000
OPEN_FINANCE_STARTUP_DELAY_MS=5000
OPEN_FINANCE_ALERT_MAX_PER_RUN=2
